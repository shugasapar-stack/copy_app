rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsIncoming() {
      return signedIn() && request.resource.data.uid == request.auth.uid;
    }

    function ownsExisting() {
      return signedIn() && resource.data.uid == request.auth.uid;
    }

    match /users/{uid} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == uid;
    }

    match /journals/{entryId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsExisting();
    }

    match /moods/{moodId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsExisting();
    }

    match /ai_chats/{messageId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsExisting();
    }

    match /voice_journals/{voiceId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsExisting();
    }

    match /photo_memories/{photoId} {
      allow create: if ownsIncoming();
      allow read, update, delete: if ownsExisting();
    }

    match /community_posts/{postId} {
      allow read: if signedIn();
      allow create: if ownsIncoming();
      allow update: if signedIn();
      allow delete: if ownsExisting();
    }
  }
}
